# ─── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://app:app@localhost:5432/financas

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Autenticação (Better Auth) ────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
BETTER_AUTH_SECRET=

# ─── LLM — OpenRouter ──────────────────────────────────────────────────────────
# Usado na ingestão por IA e no chat "Pergunte às suas finanças"
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── STT — Groq Whisper ────────────────────────────────────────────────────────
# Usado na ingestão por áudio
# https://console.groq.com/keys
GROQ_API_KEY=

# ─── Object storage — MinIO ────────────────────────────────────────────────────
# Os valores abaixo correspondem ao docker-compose.yml padrão
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=financas

# ─── Push notifications — VAPID ────────────────────────────────────────────────
# Opcional: sem essas variáveis as notificações push são silenciosas (no-op)
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
