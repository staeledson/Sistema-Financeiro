generator client {
  provider = "prisma-client"
  output   = "../apps/api/generated/prisma"
}

generator worker_client {
  provider = "prisma-client"
  output   = "../apps/worker/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Better Auth tables ---

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  sessions     Session[]
  accounts     Account[]
  workspaces   Workspace[]        @relation("WorkspaceCreator")
  memberships  WorkspaceMember[]
  transactions   Transaction[]      @relation("TransactionCreator")
  aiJobs         AiJob[]            @relation("AiJobCreator")
  drafts         TransactionDraft[] @relation("DraftCreator")
  importBatches        ImportBatch[]       @relation("ImportBatchCreator")
  goalContributions    GoalContribution[]  @relation("GoalContributor")
  sentInvitations      Invitation[]        @relation("InvitationSender")
  transactionSplits    TransactionSplit[]
  chatConversations    ChatConversation[]
  pushSubscriptions    PushSubscription[]
  scheduledBills       ScheduledBill[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// --- Domínio ---

enum RuleMatchType {
  contains
  equals
  regex
}

enum InsightType {
  spike
  subscription
  forecast
  summary
  budget_alert
  goal_alert
}

enum BudgetMethod {
  fixed
  fifty_thirty_twenty
}

enum CategoryBucket {
  needs
  wants
  savings
}

enum WorkspaceType {
  personal
  family
  business
}

enum MemberRole {
  owner
  admin
  member
  viewer
}

enum InvitationStatus {
  pending
  accepted
  expired
  revoked
}

model Workspace {
  id          String        @id @default(cuid())
  type        WorkspaceType
  name        String
  currency    String        @default("BRL") @db.Char(3)
  createdById String
  createdBy   User          @relation("WorkspaceCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members          WorkspaceMember[]
  bankAccounts     BankAccount[]
  categories       Category[]
  tags             Tag[]
  transactions     Transaction[]
  aiJobs           AiJob[]
  drafts           TransactionDraft[]
  importBatches    ImportBatch[]
  importMappings   ImportMapping[]
  categoryRules    CategoryRule[]
  insights         Insight[]
  budgets          Budget[]
  goals            Goal[]
  invitations        Invitation[]
  businessProfile    BusinessProfile?
  chatConversations  ChatConversation[]
  pushSubscriptions  PushSubscription[]
  scheduledBills     ScheduledBill[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        MemberRole
  createdAt   DateTime   @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@map("workspace_members")
}

// --- Financeiro ---

enum AccountType {
  checking
  savings
  credit_card
  cash
  investment
}

enum CategoryType {
  income
  expense
}

enum TransactionType {
  income
  expense
  transfer
}

model BankAccount {
  id                  String      @id @default(cuid())
  workspaceId         String
  workspace           Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type                AccountType
  name                String
  openingBalanceCents BigInt      @default(0)
  archived            Boolean     @default(false)
  createdAt           DateTime    @default(now())

  transactions       Transaction[]      @relation("TransactionAccount")
  sourceTransactions Transaction[]      @relation("TransactionSource")
  destTransactions   Transaction[]      @relation("TransactionDest")
  drafts             TransactionDraft[]
  importBatches      ImportBatch[]

  @@index([workspaceId])
  @@map("bank_accounts")
}

model Category {
  id          String       @id @default(cuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type        CategoryType
  parentId    String?
  parent      Category?    @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[]   @relation("CategoryParent")
  name        String
  icon        String?
  color       String?
  bucket      CategoryBucket?
  isSystem    Boolean      @default(false)

  transactions    Transaction[]
  drafts          TransactionDraft[]
  categoryRules   CategoryRule[]
  budgets         Budget[]
  scheduledBills  ScheduledBill[]

  @@index([workspaceId])
  @@map("categories")
}

model Tag {
  id          String           @id @default(cuid())
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  tags        TransactionTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("tags")
}

model Transaction {
  id              String          @id @default(cuid())
  workspaceId     String
  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type            TransactionType
  amountCents     BigInt
  date            DateTime        @db.Date
  accountId       String?
  account         BankAccount?    @relation("TransactionAccount", fields: [accountId], references: [id])
  sourceAccountId String?
  sourceAccount   BankAccount?    @relation("TransactionSource", fields: [sourceAccountId], references: [id])
  destAccountId   String?
  destAccount     BankAccount?    @relation("TransactionDest", fields: [destAccountId], references: [id])
  categoryId      String?
  category        Category?       @relation(fields: [categoryId], references: [id])
  description     String?
  counterparty    String?
  source            String          @default("manual")
  importFingerprint String?
  importBatchId     String?
  importBatch       ImportBatch?    @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  costCenter        String?
  createdById       String
  createdBy         User            @relation("TransactionCreator", fields: [createdById], references: [id])
  createdAt         DateTime        @default(now())

  tags   TransactionTag[]
  splits TransactionSplit[]

  @@unique([workspaceId, importFingerprint])
  @@index([workspaceId, date])
  @@map("transactions")
}

model ImportBatch {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accountId   String?
  account     BankAccount?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  format      ImportFormat
  status      ImportStatus  @default(preview)
  fileRef     String?
  rowCount    Int           @default(0)
  dupCount    Int           @default(0)
  createdById String
  createdBy   User          @relation("ImportBatchCreator", fields: [createdById], references: [id])
  createdAt   DateTime      @default(now())

  transactions Transaction[]

  @@index([workspaceId])
  @@map("import_batches")
}

model ImportMapping {
  id          String       @id @default(cuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  format      ImportFormat
  mapping     Json

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("import_mappings")
}

model TransactionTag {
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tagId         String
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
  @@map("transaction_tags")
}

// --- Ingestão por IA ---

enum AiJobKind {
  parse_text
  parse_image
  parse_audio
  parse_invoice
  categorize
  compute_insights
}

enum ImportFormat {
  csv
  ofx
  pdf
}

enum ImportStatus {
  preview
  committed
  failed
}

enum AiJobStatus {
  queued
  processing
  done
  failed
}

enum DraftStatus {
  draft
  discarded
}

model AiJob {
  id          String      @id @default(cuid())
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  kind        AiJobKind
  status      AiJobStatus @default(queued)
  inputRef    String?
  result      Json?
  error       String?
  costTokens  Int?
  createdById String
  createdBy   User        @relation("AiJobCreator", fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())

  drafts TransactionDraft[]

  @@index([workspaceId])
  @@map("ai_jobs")
}

model TransactionDraft {
  id                String           @id @default(cuid())
  workspaceId       String
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  aiJobId           String?
  aiJob             AiJob?           @relation(fields: [aiJobId], references: [id], onDelete: SetNull)
  kind              AiJobKind
  status            DraftStatus      @default(draft)
  type              TransactionType?
  amountCents       BigInt?
  date              DateTime?        @db.Date
  description       String?
  counterparty      String?
  suggestedCategory String?
  categoryId        String?
  category          Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  accountId         String?
  account           BankAccount?     @relation(fields: [accountId], references: [id], onDelete: SetNull)
  confidence        Float?
  sourceRef         String?
  createdById       String
  createdBy         User             @relation("DraftCreator", fields: [createdById], references: [id])
  createdAt         DateTime         @default(now())

  @@index([workspaceId, status])
  @@map("transaction_drafts")
}

// --- Fase 4: Inteligência ---

model CategoryRule {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  matchType   RuleMatchType
  pattern     String
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  priority    Int           @default(100)
  createdAt   DateTime      @default(now())

  @@unique([workspaceId, matchType, pattern])
  @@index([workspaceId, priority(sort: Desc)])
  @@map("category_rules")
}

model Insight {
  id          String      @id @default(cuid())
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type        InsightType
  dedupKey    String
  period      String      @default("")
  payload     Json
  read        Boolean     @default(false)
  createdAt   DateTime    @default(now())

  @@unique([workspaceId, type, dedupKey, period])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("insights")
}

model Budget {
  id          String       @id @default(cuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  method      BudgetMethod
  categoryId  String?
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  limitCents  BigInt?
  createdAt   DateTime     @default(now())

  @@index([workspaceId])
  @@map("budgets")
}

model Goal {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  targetCents BigInt
  savedCents  BigInt   @default(0)
  deadline    DateTime? @db.Date
  createdAt   DateTime  @default(now())

  contributions GoalContribution[]

  @@index([workspaceId])
  @@map("goals")
}

model GoalContribution {
  id          String   @id @default(cuid())
  goalId      String
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  amountCents BigInt
  date        DateTime @db.Date
  createdById String
  createdBy   User     @relation("GoalContributor", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([goalId])
  @@map("goal_contributions")
}

// --- Fase 5: Família & PJ ---

model Invitation {
  id          String           @id @default(cuid())
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        MemberRole       @default(member)
  token       String           @unique @default(cuid())
  status      InvitationStatus @default(pending)
  expiresAt   DateTime
  invitedById String
  invitedBy   User             @relation("InvitationSender", fields: [invitedById], references: [id])
  createdAt   DateTime         @default(now())

  @@index([workspaceId])
  @@index([token])
  @@map("invitations")
}

model TransactionSplit {
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  shareCents    BigInt

  @@id([transactionId, userId])
  @@index([transactionId])
  @@map("transaction_splits")
}

model BusinessProfile {
  workspaceId String    @id
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cnpj        String?
  legalName   String?
  updatedAt   DateTime  @updatedAt

  @@map("business_profiles")
}

// --- Fase 6: Chat ---

model ChatConversation {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  title       String    @default("")
  createdAt   DateTime  @default(now())
  messages    ChatMessage[]

  @@index([workspaceId])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  toolResults    Json?
  chartSpec      Json?
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@map("chat_messages")
}

// --- Fase 8: PWA & Engajamento ---

model PushSubscription {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint    String    @unique
  p256dh      String
  auth        String
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@map("push_subscriptions")
}

enum Recurrence {
  once
  weekly
  monthly
  yearly
}

model ScheduledBill {
  id          String     @id @default(cuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  amountCents BigInt
  dueDate     DateTime   @db.Date
  recurrence  Recurrence @default(monthly)
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  active      Boolean    @default(true)
  createdById String
  createdBy   User       @relation(fields: [createdById], references: [id])
  createdAt   DateTime   @default(now())

  @@index([workspaceId])
  @@map("scheduled_bills")
}
