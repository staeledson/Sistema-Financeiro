generator client {
  provider = "prisma-client"
  output   = "../apps/api/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Better Auth tables ---

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  sessions     Session[]
  accounts     Account[]
  workspaces   Workspace[]       @relation("WorkspaceCreator")
  memberships  WorkspaceMember[]
  transactions Transaction[]     @relation("TransactionCreator")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// --- Domínio ---

enum WorkspaceType {
  personal
  family
  business
}

enum MemberRole {
  owner
  admin
  member
  viewer
}

model Workspace {
  id          String        @id @default(cuid())
  type        WorkspaceType
  name        String
  currency    String        @default("BRL") @db.Char(3)
  createdById String
  createdBy   User          @relation("WorkspaceCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members      WorkspaceMember[]
  bankAccounts BankAccount[]
  categories   Category[]
  tags         Tag[]
  transactions Transaction[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        MemberRole
  createdAt   DateTime   @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@map("workspace_members")
}

// --- Financeiro ---

enum AccountType {
  checking
  savings
  credit_card
  cash
  investment
}

enum CategoryType {
  income
  expense
}

enum TransactionType {
  income
  expense
  transfer
}

model BankAccount {
  id                  String      @id @default(cuid())
  workspaceId         String
  workspace           Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type                AccountType
  name                String
  openingBalanceCents BigInt      @default(0)
  archived            Boolean     @default(false)
  createdAt           DateTime    @default(now())

  transactions       Transaction[] @relation("TransactionAccount")
  sourceTransactions Transaction[] @relation("TransactionSource")
  destTransactions   Transaction[] @relation("TransactionDest")

  @@index([workspaceId])
  @@map("bank_accounts")
}

model Category {
  id          String       @id @default(cuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type        CategoryType
  parentId    String?
  parent      Category?    @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[]   @relation("CategoryParent")
  name        String
  icon        String?
  color       String?
  isSystem    Boolean      @default(false)

  transactions Transaction[]

  @@index([workspaceId])
  @@map("categories")
}

model Tag {
  id          String           @id @default(cuid())
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  tags        TransactionTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("tags")
}

model Transaction {
  id              String          @id @default(cuid())
  workspaceId     String
  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type            TransactionType
  amountCents     BigInt
  date            DateTime        @db.Date
  accountId       String?
  account         BankAccount?    @relation("TransactionAccount", fields: [accountId], references: [id])
  sourceAccountId String?
  sourceAccount   BankAccount?    @relation("TransactionSource", fields: [sourceAccountId], references: [id])
  destAccountId   String?
  destAccount     BankAccount?    @relation("TransactionDest", fields: [destAccountId], references: [id])
  categoryId      String?
  category        Category?       @relation(fields: [categoryId], references: [id])
  description     String?
  counterparty    String?
  source          String          @default("manual")
  createdById     String
  createdBy       User            @relation("TransactionCreator", fields: [createdById], references: [id])
  createdAt       DateTime        @default(now())

  tags TransactionTag[]

  @@index([workspaceId, date])
  @@map("transactions")
}

model TransactionTag {
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tagId         String
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
  @@map("transaction_tags")
}
